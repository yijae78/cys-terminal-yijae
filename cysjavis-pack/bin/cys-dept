#!/usr/bin/env bash
# cys-dept — 부서(독립 데몬) 운용 정식 도구 (멀티마스터 정식화 F2)
#
#   cys-dept launch <name>    부서 데몬 spawn + ACL 시드 + 부서장 자리 + (부서≥1)CEO 승격 + 레지스트리 등재
#   cys-dept down   <name>    teardown: SIGTERM + 소켓/lock 정리 + 레지스트리 해제 + (마지막)CEO 강등
#   cys-dept rotate <name>    버전 스큐 세대교체(재기동): 데몬 프로세스만 정지→새 on-disk cysd로 재기동
#                             (★폐기 아님 — 레지스트리·묘비·CEO 불변). stdout 마지막 줄=rotated <name>: vX→vY
#   cys-dept list             부서명 목록
#   cys-dept sock   <name>    부서 소켓 경로 출력 (broadcast fan-out 루프용)
#   cys-dept <name> -- <cmd>  부서 컨텍스트(CYS_SOCKET+CYS_PACK_DIR)로 명령 실행
#
# 격리 불변식: 부서마다 socket의 *부모 디렉토리*와 pack_dir이 서로 달라야 한다(state_dir·ACL 격리).
# 단일 진입점: Tauri/UI·CLI 모두 이 도구를 거쳐 부서를 운용한다(직접 cysd spawn 금지 — 레지스트리/ACL 미시드 방지).
set -euo pipefail

# RC-16: Windows(MSYS/Git-Bash)가 한글 사용자명 $HOME을 CP949로 깨뜨려(예: "신이재"→½ÅÀÌÀç)
# depts.json·pack_dir 등 모든 홈 경로 접근이 실패하는 문제 우회(＋부서 클릭→블랙화면 롤백의 근인).
# USERPROFILE은 정상 유지되므로 cygpath -u로 올바른 POSIX 홈을 재획득한다. LANG/LC_ALL로는 못 고침
# (bash 진입 시점에 이미 CP949). unix는 USERPROFILE 부재·cygpath 부재로 무영향(가드).
if [ -n "${USERPROFILE:-}" ] && command -v cygpath >/dev/null 2>&1; then
  _uhome="$(cygpath -u "$USERPROFILE" 2>/dev/null || true)"
  [ -n "$_uhome" ] && [ -d "$_uhome" ] && export HOME="$_uhome"
fi

# ★PATH 보강(GUI Finder/Dock 런칭 대응): cys.app은 launchd 기본 PATH(/usr/bin:/bin:/usr/sbin:/sbin)만
# 상속해 cys(/opt/homebrew/bin)·claude(~/.local/bin)를 못 찾는다 → 빈 셸의 `cys status`·사용자의 claude
# 수동 실행 실패·dept cysd 의 claude spawn 실패 = 0 pane. 이 도구가 spawn 하는 모든 자식(cysd·빈 셸·
# 그 아래 사용자가 실행하는 claude)이 상속하도록 단일 지점에서 로그인 셸 표준 경로를 prepend.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin${PATH:+:$PATH}"

REG="${CYS_DEPTS_JSON:-$HOME/.cys/depts.json}"
PACK_DEFAULT="$HOME/.cys/pack"
# RC-6: 폴백 경로 가드 — command -v 우선(Windows는 RC-5 runtime PATH로 cysd.exe/cys.exe 해소).
# /opt/homebrew는 macOS 전용이라 존재할 때만 폴백(Windows서 유령 경로 방지), 최종 폴백=bare 이름.
CYSD="$(command -v cysd || { [ -x /opt/homebrew/bin/cysd ] && echo /opt/homebrew/bin/cysd; } || echo cysd)"
CYS="$(command -v cys || { [ -x /opt/homebrew/bin/cys ] && echo /opt/homebrew/bin/cys; } || echo cys)"
# RC-6(codex R3.1 nit): 인라인 python heredoc이 cys를 literal이 아니라 **해소된 경로**로 실행하도록
# CYS_BIN을 env로 전파(heredoc은 프로세스 env 상속). dept_classify_idle·alive_sock 등 subprocess가 사용.
export CYS_BIN="$CYS"
# RC-6(T3 발견): Windows 번들 embeddable Python은 open() 기본 인코딩이 cp1252(charmap)라 UTF-8(한글)
# agents.json·directives 읽기가 UnicodeDecodeError로 크래시(부서 seed 실패 등). PYTHONUTF8=1로 전 python
# heredoc·자식 python을 UTF-8 기본으로 강제(unix 무영향). 개별 open(encoding=) 누락도 이걸로 방어.
export PYTHONUTF8=1

# RC-4: 부서 소켓 규약 — Windows(MSYS/Git-Bash)는 named pipe `\\.\pipe\cys-dept-<n>`
# (cysd가 CYS_SOCKET을 named pipe로 바인드·Rust cys::dept_socket_path와 정합), 그 외는 unix .sock.
dept_sock(){
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) echo "\\\\.\\pipe\\cys-dept-$1" ;;
    *) echo "$HOME/.local/state/cys-dept-$1/cys.sock" ;;
  esac
}
dept_pack(){ echo "$HOME/.cys/pack-dept-$1"; }

# ★W2a-4 의도삭제 → phoenix dept 묘비: 부서 전체 폐기(down/down-sock=의도적 teardown)를 phoenix
# 보호집합(base dept_roster)에 명시적 폐역으로 기록해, 부활 보고가 폐기된 부서를 '부활 필요'로
# 오보하지 않게 한다. best-effort — phoenix 부재·실패가 teardown을 절대 깨지 않는다(|| true·무출력).
dept_tombstone(){
  [ -n "${1:-}" ] || return 0
  ph="${CYS_PACK_DIR:-$PACK_DEFAULT}/bin/javis_phoenix.py"
  [ -f "$ph" ] || return 0
  python3 "$ph" tombstone "$1" --dept >/dev/null 2>&1 || true
}

# RC-15(D7): 부서 로그·상태 디렉토리 — Windows named pipe 소켓(\\.\pipe\...)은 dirname/디렉토리 개념이
# 없어(RC-4 파생) mkdir·로그 경로가 깨진다. 실 디렉토리로 분리:
#   Windows = %LOCALAPPDATA%\cys\cys-dept-<name> — ★RC-13 state_dir 슬러그와 **동일 규약**(pipe_slug
#     `\\.\pipe\cys-dept-<name>`→`cys-dept-<name>`)이라 로그+transcripts.db+feed.jsonl가 한 폴더로 모임.
#   unix = 소켓 부모(기존 dirname($sock)=~/.local/state/cys-dept-<name>·무회귀).
dept_logdir(){
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) echo "${LOCALAPPDATA:-$HOME/AppData/Local}/cys/cys-dept-$1" ;;
    *) dirname "$(dept_sock "$1")" ;;
  esac
}

# RC-6: OS중립 graceful kill — unix=SIGTERM→대기→SIGKILL, Windows(MSYS/Git-Bash)=taskkill(트리·강제).
# Windows 프로세스는 unix 시그널을 안 받으므로 kill/kill -9가 무효 → taskkill //PID //T //F로 분기
# (MSYS는 `/PID`를 경로로 변환하므로 `//PID` 형식 사용).
graceful_kill(){
  local pid="$1"
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) taskkill //PID "$pid" //T //F >/dev/null 2>&1 || true ;;
    *)
      kill "$pid" 2>/dev/null || true
      for _i in 1 2 3 4 5 6; do kill -0 "$pid" 2>/dev/null || break; sleep 0.3; done
      kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true ;;
  esac
}

reg_init(){ [ -f "$REG" ] || { mkdir -p "$(dirname "$REG")"; printf '{"depts":{}}\n' > "$REG"; }; }
# RC-17: $REG를 -c 문자열에 삽입하면 MSYS 경로 자동변환이 적용되지 않아(인자만 변환) Windows
# 네이티브 Python이 POSIX 경로(/c/...)를 열지 못한다 → argv 전달로 통일(reg_upsert와 동일 패턴·unix 무영향).
reg_count(){ reg_init; python3 -c "import json,sys;print(len(json.load(open(sys.argv[1]))['depts']))" "$REG"; }
reg_names(){ reg_init; python3 -c "import json,sys;[print(k) for k in json.load(open(sys.argv[1]))['depts']]" "$REG"; }
# reg_upsert/reg_remove: 동시 부서 운용 시 lost-update 방지 — fcntl.flock으로 RMW 직렬화 +
# temp+os.replace 원자 교체(읽는 쪽이 부분 파일을 보지 않음). macOS엔 flock(1) CLI가 없어 python fcntl 사용.
reg_upsert(){ reg_init; python3 - "$REG" "$1" "$2" "$3" <<'PY'
import json,sys,os
try:
    import fcntl
    def _lk(f): fcntl.flock(f, fcntl.LOCK_EX)
    def _ulk(f): fcntl.flock(f, fcntl.LOCK_UN)
except ImportError:  # RC-6 Windows: fcntl 부재 → msvcrt 바이트락(파일 닫힘 시 해제·_ulk no-op 안전)
    import msvcrt
    def _lk(f):
        try: msvcrt.locking(f.fileno(), msvcrt.LK_LOCK, 1)
        except OSError: pass
    def _ulk(f): pass
p,n,s,k=sys.argv[1:5]
lf=open(p+'.lock','w'); _lk(lf)
try:
    try: d=json.load(open(p))
    except Exception: d={'depts':{}}
    # F2(codex#2): full-replace 대신 merge — 기존 메타(display_name/account/mission_key) 보존.
    # launch 재진입 시 create가 심은 메타 소실 방지. 신규 엔트리는 3필드만(하위호환).
    e=d.setdefault('depts',{}).setdefault(n,{})
    e.update({'socket':s,'pack_dir':k,'role':'dept-master'})
    tmp=p+'.tmp.%d'%os.getpid()
    with open(tmp,'w') as f: json.dump(d,f,ensure_ascii=False,indent=2); f.flush(); os.fsync(f.fileno())
    os.replace(tmp,p)
finally: _ulk(lf)
PY
}
reg_remove(){ reg_init; python3 - "$REG" "$1" <<'PY'
import json,sys,os
try:
    import fcntl
    def _lk(f): fcntl.flock(f, fcntl.LOCK_EX)
    def _ulk(f): fcntl.flock(f, fcntl.LOCK_UN)
except ImportError:  # RC-6 Windows: fcntl 부재 → msvcrt 바이트락(파일 닫힘 시 해제·_ulk no-op 안전)
    import msvcrt
    def _lk(f):
        try: msvcrt.locking(f.fileno(), msvcrt.LK_LOCK, 1)
        except OSError: pass
    def _ulk(f): pass
p,n=sys.argv[1:3]
lf=open(p+'.lock','w'); _lk(lf)
try:
    try: d=json.load(open(p))
    except Exception: d={'depts':{}}
    d.setdefault('depts',{}).pop(n,None)
    tmp=p+'.tmp.%d'%os.getpid()
    with open(tmp,'w') as f: json.dump(d,f,ensure_ascii=False,indent=2); f.flush(); os.fsync(f.fileno())
    os.replace(tmp,p)
finally: _ulk(lf)
PY
}
# reg_set_meta: 기존 엔트리에 display_name·account·mission_key 를 merge(socket/pack_dir/role 보존).
# reg_upsert 시그니처 불변(launch 회귀0) — ＋부서 자동화(cys-dept create)용 신설. flock RMW·원자교체.
reg_set_meta(){ reg_init; python3 - "$REG" "$1" "$2" "$3" <<'PY'
import json,sys,os
try:
    import fcntl
    def _lk(f): fcntl.flock(f, fcntl.LOCK_EX)
    def _ulk(f): fcntl.flock(f, fcntl.LOCK_UN)
except ImportError:  # RC-6 Windows: fcntl 부재 → msvcrt 바이트락(파일 닫힘 시 해제·_ulk no-op 안전)
    import msvcrt
    def _lk(f):
        try: msvcrt.locking(f.fileno(), msvcrt.LK_LOCK, 1)
        except OSError: pass
    def _ulk(f): pass
p,n,disp,acct=sys.argv[1:5]
lf=open(p+'.lock','w'); _lk(lf)
try:
    try: d=json.load(open(p))
    except Exception: d={'depts':{}}
    e=d.setdefault('depts',{}).get(n)
    if e is None:   # ★fail-closed(CSO GAP①): create가 base 엔트리 선기록 → 부재=버그 → no-op 말고 에러
        sys.stderr.write("reg_set_meta: 엔트리 부재 %s — fail-closed(예약 base 미기록=버그)\n"%n); sys.exit(1)
    e['display_name']=disp; e['account']=acct   # mission_key는 예약시 원자기록(중복 set 제거)
    tmp=p+'.tmp.%d'%os.getpid()
    with open(tmp,'w') as f: json.dump(d,f,ensure_ascii=False,indent=2); f.flush(); os.fsync(f.fileno())
    os.replace(tmp,p)
finally: _ulk(lf)
PY
}

# 부서 데몬 ACL 시드 — external(CEO·오너셸)→worker 차단. fail-closed: 없으면 격리 붕괴이므로 항상 시드.
seed_acl(){
  local pk="$1"; mkdir -p "$pk"
  cat > "$pk/acl.json" <<'JSON'
{
  "_doc": "부서 데몬 ACL — CEO·외부는 워커 직접 조향 불가(부서장 master 경유). cys-dept 시드.",
  "default": "allow",
  "rules": [
    { "from": "external", "to": "worker*", "allow": false },
    { "from": "reviewer-*", "to": "worker*", "allow": false },
    { "from": "external", "to": "master", "allow": true }
  ]
}
JSON
}

# F1(codex#1·verdict-D): 부서 pack 에 agents.json 을 명시 시드 — claude.cmd 의 CLAUDE_CONFIG_DIR 을
# 해당 account dir 로 **직접 치환**(하드코딩). 이렇게 하면 cysd 임베드 버전·CYS_ACCOUNT_DIR 전파(patch2)
# 에 비의존하여 계정격리가 완결된다(rebuild 전 deployed 구 cysd 로도 동작). 가드 str-replace + 쓰기후
# json 검증 + 리터럴 미발견 시 fail-closed(비격리 시드 금지). 멱등(재시드 시 account 만 갱신).
seed_agents_account(){
  local pk="$1" acct_dir="$2"
  local src="${CYS_PACK_DIR:-$HOME/.cys/pack}/agents.json"
  mkdir -p "$pk"
  python3 - "$src" "$pk/agents.json" "$acct_dir" <<'PY'
import json,sys,os,re
src,dst,acct=sys.argv[1:4]
d=json.load(open(src,encoding="utf-8"))                 # RC-6(T3): Windows cp1252 기본 회피(한글 UTF-8)
claude=d.get("claude") or {}
env=claude.get("env")
# RC-3 파급 수정: agents.json이 cmd+env 구조가 되면서 CLAUDE_CONFIG_DIR이 cmd 리터럴→env 맵으로 이동했다.
# 신구조=env["CLAUDE_CONFIG_DIR"]를 account dir로 치환(계정 격리). 레거시(cmd 인라인 리터럴)는 하위호환 str-replace.
# 둘 다 없으면 fail-closed(비격리 시드 금지 — 기존 안전규약 유지).
if isinstance(env, dict) and "CLAUDE_CONFIG_DIR" in env:
    env["CLAUDE_CONFIG_DIR"]=acct
elif re.search(r'CLAUDE_CONFIG_DIR="[^"]*"', claude.get("cmd","")):
    claude["cmd"]=re.sub(r'CLAUDE_CONFIG_DIR="[^"]*"',
                         lambda m: 'CLAUDE_CONFIG_DIR="%s"'%acct, claude["cmd"], count=1)
else:
    sys.stderr.write("seed_agents_account: CLAUDE_CONFIG_DIR(env 맵/cmd 리터럴) 미발견 — abort(비격리 시드 금지)\n"); sys.exit(1)
tmp=dst+".tmp.%d"%os.getpid()
with open(tmp,"w") as f: json.dump(d,f,ensure_ascii=False,indent=2); f.flush(); os.fsync(f.fileno())
json.load(open(tmp))                                    # 쓰기후 파싱 검증
os.replace(tmp,dst)
PY
}

# 부서 schedule 시드 — owner-progress-report(5/15분 보고)는 최상위(owner/CEO) 데몬만 돌려야 한다.
# pack install이 임베드 schedule.json(owner-보고 job)을 모든 pack에 깔므로, 부서 pack은 데몬 기동
# 후 빈 jobs로 덮어쓴다(데몬 30초 내 핫리로드 + install은 user-modified 보존으로 영속). 부서마다
# owner-보고가 N배 중복 실행되는 자원 낭비·노이즈 차단.
seed_schedule(){
  local pk="$1"; mkdir -p "$pk"
  printf '{\n  "_doc": "부서 데몬 schedule — owner 진행보고는 최상위만. cys-dept가 빈 jobs로 시드(중복 실행 방지).",\n  "jobs": []\n}\n' > "$pk/schedule.json"
}

# 부서 데몬은 첫 기동 시 pack install(수백 파일)로 listening까지 지연될 수 있어 폴링 간격을 둔다(최대 ~12s).
ready(){ local s="$1" i; for i in $(seq 1 120); do CYS_SOCKET="$s" "$CYS" ping >/dev/null 2>&1 && return 0; sleep 0.1; done; return 1; }

# allocate 계정격리(Fix1'): 기본계정 base config dir 해석. 카탈로그 accounts 맵 우선(있으면), 없으면
# ~/.cys/claude-<account> 규약 fallback. 항상 경로를 산출(빈 문자열이면 호출부가 fail-closed).
resolve_default_base(){
  local acct="$1" cat="${CYS_DEPT_CATALOG:-$HOME/.cys/dept-catalog.json}" b
  if [ -f "$cat" ]; then
    b="$(python3 - "$cat" "$acct" <<'PY'
import json,sys,os
cat,acct=sys.argv[1:3]
try: d=json.load(open(cat))
except Exception: sys.exit(1)
a=d.get('accounts',{}).get(acct)
if not a: sys.exit(2)
print(os.path.expandvars(a))
PY
)" && [ -n "$b" ] && { echo "$b"; return 0; }
  fi
  [ -n "${HOME:-}" ] || return 1            # 규약 fallback도 불가 → fail-closed 신호
  echo "$HOME/.cys/claude-$acct"
}

# 데몬 소켓의 live(미exited) surface role 목록을 출력(줄당 1개·role 없으면 '-'). cys list 파싱(read-only).
# ★NO_AUTOSTART(identify autostart 감사 2026-07-10): 읽기 프로브가 죽은 소켓에서 cysd를 되살리지 않게.
dept_live_roles(){
  CYS_NO_AUTOSTART=1 CYS_SOCKET="$1" "$CYS" list 2>/dev/null | python3 - <<'PY'
import sys
for line in sys.stdin:
    f=line.rstrip("\n").split("\t")
    if len(f)<4: continue
    role=f[1][5:] if f[1].startswith("role=") else ""
    if f[3].endswith("true"): continue   # exited surface 무시
    print(role if role else "-")
PY
}
# 데몬에 live master surface가 있나? (더블master guard용)
# ★[6] pipefail+EPIPE 하드닝: dept_live_roles|grep -qx는 grep 조기종료 시 상류 python이 SIGPIPE→비0→
#   pipefail이 매치(0)를 비0(미발견)로 오판할 수 있다. 출력을 변수로 받아 here-string grep(파이프 제거).
dept_has_master(){
  local roles; roles="$(dept_live_roles "$1")" || true
  grep -qx "master" <<<"$roles"
}

# 소켓 생존 probe → cys ping(RC-6: unix 소켓·Windows named pipe 양쪽 OS중립·AF_UNIX 제거). exit 0=alive.
sock_alive(){ CYS_SOCKET="$1" "$CYS" ping >/dev/null 2>&1; }

# ★reaper 유휴 판정(read-only): stdout="IDLE" | "ACTIVE:<이유>".
#   유휴 = live(미exited) master surface 부재 AND (agent-backed·비-cso/리뷰어) live surface 부재.
#   ★[1] surface.list RPC로 surface별 agent(agent_meta name)까지 조회(cys list엔 agent 필드 없음) → 빈 zsh
#        placeholder(agent=None)는 활동으로 치지 않아 실제 누수(GUI 빈 첫 pane·각성전 데몬)를 회수, 실 에이전트 워커는 보호.
#   ★[5] grace: reserved_at(인자) 또는 소켓 mtime이 CYS_DEPT_REAP_GRACE(기본 60)초 이내면 mid-boot/사람
#        셸 보호로 ACTIVE 취급. probe 불가는 보수적 ACTIVE(오회수 방지).
dept_classify_idle(){ CYS_REAP_GRACE="${CYS_DEPT_REAP_GRACE:-60}" python3 - "$1" "${2:-0}" <<'PY'
import sys,os,json,time,subprocess
sk=sys.argv[1]; rat=float(sys.argv[2] or 0)
GRACE=float(os.environ.get("CYS_REAP_GRACE","60")); now=time.time()
recent=rat
try: recent=max(recent, os.stat(sk).st_mtime)   # named pipe(Windows)면 OSError→rat만 사용
except OSError: pass
if recent and now-recent < GRACE:
    print("ACTIVE:grace(%.0fs<%g)"%(now-recent,GRACE)); sys.exit(0)
# RC-6 잔여(T2.1·codex CONFIRMED): AF_UNIX surface.list → `cys status --json`(OS중립·named pipe 대응).
# result에 surfaces[{role,agent,exited}] 포함(handlers 2320·2324·2328·request가 result 언랩). 판정 로직 동일.
try:
    r=subprocess.run([os.environ.get("CYS_BIN","cys"),"status","--json"], env={**os.environ,"CYS_SOCKET":sk},
                     capture_output=True, timeout=5)
    if r.returncode!=0: raise RuntimeError("cys status rc=%d"%r.returncode)
    surfaces=(json.loads(r.stdout.decode("utf-8","replace")) or {}).get("surfaces",[])
except Exception:
    print("ACTIVE:probe-failed"); sys.exit(0)   # 조회 불가 → 보수적 비유휴(오회수 차단·정책 유지)
for s in surfaces:
    if s.get("exited"): continue
    role=s.get("role") or ""
    if role=="master":
        print("ACTIVE:master"); sys.exit(0)
    # agent-backed = surface에 에이전트가 배정됨(agent_meta name 존재). ★보수적: agent_alive(=seen) 대신
    # agent 존재를 쓴다 — 부팅 중(agent_meta 세팅·아직 미seen) 워커를 오회수하지 않기 위함([5] 안전우선).
    # 빈 zsh placeholder(agent=None)는 활동 아님 → 실제 누수 회수([1]). cso/리뷰어는 지원노드라 제외.
    if s.get("agent") is not None and role!="cso" and not role.startswith("reviewer"):
        print("ACTIVE:agent(%s/%s)"%(role or '-', s.get('agent'))); sys.exit(0)
print("IDLE")
PY
}

# ★WP-12: 기본 데몬(cys 기본 소켓) role=master 원본 세션에 현재 MASTER_DIRECTIVE.md 를 라이브 재주입.
#   파일 교체(MASTER↔CEO)만으로는 이미 실행 중인 원본 master 컨텍스트가 안 바뀐다(감사 에러②) →
#   승격/강등 직후 원본 master 1개(부서 소켓 아님)에 재주입해 라이브 반영한다. env -u CYS_SOCKET 로
#   상속된 부서 소켓을 지우고 cys 기본 소켓(원본 master)만 대상. agent 있는 실 master만 재주입하고
#   빈 셸(agent=None)·조회불가는 skip(빈 zsh 오해석 각성핑 차단 — WP-11 정합). best-effort(부서 lifecycle 불파괴).
ceo_reinject_master(){
  local why="${1:-directive}" has_agent
  has_agent=$(env -u CYS_SOCKET "$CYS" status --json 2>/dev/null | python3 -c '
import json,sys
try: d=json.load(sys.stdin)
except Exception: sys.exit(2)
for s in d.get("surfaces",[]):
    if s.get("role")=="master" and not s.get("exited"):
        print("yes" if s.get("agent") is not None else "no"); sys.exit(0)
sys.exit(3)' 2>/dev/null) || true
  if [ "$has_agent" = "yes" ]; then
    env -u CYS_SOCKET "$CYS" reinject --role master >/dev/null 2>&1 \
      && echo "[cys-dept] 원본 master 라이브 재주입($why) 완료" >&2 \
      || echo "[cys-dept] WARN: 원본 master 라이브 재주입($why) 미확정 — read-screen 점검" >&2
  else
    echo "[cys-dept] 원본 master 재주입($why) skip: 실 agent 없음(빈 셸)·조회불가 — 각성핑 미발사(WP-11 정합)" >&2
  fi
}
# CEO 승격: 부서가 1개 이상이면 기본 데몬을 CEO로(디렉티브 교체, 가역 백업). 부서 0이면 표준 master 보존(하위호환).
ceo_promote(){
  local md="$PACK_DEFAULT/directives/MASTER_DIRECTIVE.md"
  local ceo="$PACK_DEFAULT/directives/CEO_TEMPLATE.md"
  [ -f "$ceo" ] || { echo "[cys-dept] CEO 템플릿 없음 — 승격 생략(cys init-pack 필요)"; return 0; }
  cmp -s "$md" "$ceo" 2>/dev/null && return 0
  [ -f "$md.pre-ceo" ] || cp "$md" "$md.pre-ceo"
  cp "$ceo" "$md"
  echo "[cys-dept] 기본 데몬 CEO 승격(directives 교체·백업 .pre-ceo)"
  ceo_reinject_master "CEO 승격"
}
ceo_demote(){
  local md="$PACK_DEFAULT/directives/MASTER_DIRECTIVE.md"
  [ -f "$md.pre-ceo" ] || return 0
  cp "$md.pre-ceo" "$md"; rm -f "$md.pre-ceo"
  echo "[cys-dept] CEO 강등(표준 master 원복)"
  ceo_reinject_master "표준 master 복귀"
}

cmd="${1:?usage: cys-dept launch|allocate|create|down|down-sock|rotate|reap|list|sock <name> | <name> -- <cmd>}"
# ★단일소유 기술 강제(CEO 2026-06-22): 부서 lifecycle mutation은 CSO(CYS_ROLE=cso)·GUI(role 없음·오너
# 직접)만 허용한다. roled 비-CSO 노드(부서장 master·워커·리뷰어·CEO)의 cys-dept create/down 직접 호출을
# 차단해 다중주체 churn(빈 dept-N·중복·레이스)을 기술적으로 방지. (defense-in-depth — 의도적 unset 우회는
# 거버넌스 영역이나, 정상 다중 노드 churn은 차단). 읽기 전용(list/sock/<name> --)은 무제한.
case "$cmd" in
  launch|allocate|create|down|down-sock|rotate|reap)
    if [ -n "${CYS_ROLE:-}" ] && [ "${CYS_ROLE}" != "cso" ]; then
      echo "[cys-dept] ★단일소유 강제: 부서 lifecycle mutation은 CSO/GUI 전용(CYS_ROLE=$CYS_ROLE 차단·다중 churn 방지). CSO에 요청하라." >&2
      exit 7
    fi ;;
esac
case "$cmd" in
  launch)
    name="${2:?usage: cys-dept launch <name>}"
    sock="$(dept_sock "$name")"; pack="$(dept_pack "$name")"
    mkdir -p "$(dept_logdir "$name")" "$pack/directives"
    seed_acl "$pack"
    reg_upsert "$name" "$sock" "$pack"
    if ready "$sock"; then
      echo "[cys-dept] $name 이미 가동 중 — 재사용"
    else
      CYS_SOCKET="$sock" CYS_PACK_DIR="$pack" nohup "$CYSD" >"$(dept_logdir "$name")/cysd.log" 2>&1 &
      disown
      # 기동 실패 시 reg_upsert 롤백 — 유령 부서(데몬 없는 레지스트리 항목) 잔류 방지
      ready "$sock" || { reg_remove "$name"; echo "[cys-dept] ERROR: $name 데몬 기동 실패"; exit 1; }
    fi
    seed_schedule "$pack"   # owner-progress-report 제거(부서는 최상위 보고 안 함) — 데몬 30초 핫리로드로 반영
    ceo_promote
    echo "[cys-dept] $name 가동 완료 (sock=$sock pack=$pack). 부서 수=$(reg_count)"
    ;;
  allocate)
    # 번호계산+예약을 단일 flock 블록에 묶어 TOCTOU 제거 — lowest-unused dept-N을 발급·예약(원자).
    # 시나리오2: 레지스트리엔 빠졌어도 소켓을 점유 중인(죽어가는) 데몬 번호는 alive() probe로 skip.
    name=$(reg_init; python3 - "$REG" <<'PY'
import json,sys,os,re,socket as S
try:
    import fcntl
    def _lk(f): fcntl.flock(f, fcntl.LOCK_EX)
    def _ulk(f): fcntl.flock(f, fcntl.LOCK_UN)
except ImportError:  # RC-6 Windows: fcntl 부재 → msvcrt 바이트락(파일 닫힘 시 해제·_ulk no-op 안전)
    import msvcrt
    def _lk(f):
        try: msvcrt.locking(f.fileno(), msvcrt.LK_LOCK, 1)
        except OSError: pass
    def _ulk(f): pass
p=sys.argv[1]
lf=open(p+'.lock','w'); _lk(lf)
try:
    try: d=json.load(open(p))
    except Exception: d={'depts':{}}
    depts=d.setdefault('depts',{})
    home=os.path.expanduser('~')
    # ★[2] hard cap(reserve flock 안 — 동시성·원자성 유지): 죽은(미reap) 등록은 빼고 ★살아있는 데몬만 카운트.
    # RC-6: AF_UNIX→cys ping(OS중립·named pipe 대응). os.path.exists는 named pipe에 False라 제거.
    import subprocess
    def _alive_sk(sk):
        if not sk: return False
        try: return subprocess.run([os.environ.get("CYS_BIN","cys"),"ping"], env={**os.environ,"CYS_SOCKET":sk},
                                   capture_output=True, timeout=3).returncode==0
        except Exception: return False
    CAP=int(os.environ.get("CYS_DEPT_CAP","8"))
    live=sum(1 for e in depts.values() if _alive_sk(e.get('socket','')))
    if live>=CAP:
        sys.stderr.write("[cys-dept] allocate 거부: live 부서 수 %d ≥ CYS_DEPT_CAP=%d (hard cap·죽은등록 제외)\n"%(live,CAP)); sys.exit(8)
    used={int(m.group(1)) for k in depts if (m:=re.match(r'^dept-(\d+)$',k))}
    def _dept_sk(n):  # RC-6: OS별 부서 소켓(dept_sock 규약 미러) — Windows named pipe·unix .sock
        return (r"\\.\pipe\cys-dept-dept-%d"%n) if os.name=="nt" else f"{home}/.local/state/cys-dept-dept-{n}/cys.sock"
    def alive(n):  # 시나리오2: 레지스트리엔 빠졌어도 소켓 점유(죽어가는 데몬)면 그 번호 재사용 금지
        return _alive_sk(_dept_sk(n))
    N=1
    while N in used or alive(N): N+=1
    name=f"dept-{N}"
    depts[name]={'socket':_dept_sk(N),  # RC-6: OS별 소켓 규약(Windows named pipe·unix .sock)
                 'pack_dir':f"{home}/.cys/pack-dept-{name}",'role':'dept-master'}
    tmp=p+'.tmp.%d'%os.getpid()
    with open(tmp,'w') as f: json.dump(d,f,ensure_ascii=False,indent=2); f.flush(); os.fsync(f.fileno())
    os.replace(tmp,p)
    print(name)
finally: _ulk(lf)
PY
) || exit $?   # ★cap 거부(exit 8)·예약 실패 코드 그대로 전파
    [ -n "$name" ] || { echo "[cys-dept] allocate: 번호 발급 실패" >&2; exit 1; }
    trap 'reg_remove "$name" 2>/dev/null || true' EXIT   # 예약 후 비정상종료=예약 회수(SIGKILL 제외)
    sock="$(dept_sock "$name")"; pack="$(dept_pack "$name")"
    # ★계정격리(Fix1'): 기본계정 base 해석 → 부서별 fork dir(<base>-<name>). base 해석불가=fail-closed.
    # 기본계정은 CYS_DEPT_DEFAULT_ACCOUNT로 명시 지정한다(공개 배포본에 특정 오너 핸들을 박지 않는다 —
    # 운영자가 한 번 설정: export CYS_DEPT_DEFAULT_ACCOUNT=<account>).
    # 기본계정 미지정 시 fail-close 대신 일반 네임스페이스 'default'로 폴백 → +부서 버튼이 즉시 동작한다.
    # 부서는 여전히 <base>-<name>(각 부서 고유 dir)로 개별 격리되고, 'default'는 특정 오너 핸들이 아니므로
    # "공개 배포본에 오너 핸들 미주입" 설계 취지도 유지된다. 명시 격리는 export CYS_DEPT_DEFAULT_ACCOUNT=<account>(우선).
    acct="${CYS_DEPT_DEFAULT_ACCOUNT:-default}"
    base="$(resolve_default_base "$acct")" || { echo "[cys-dept] allocate: 기본계정 base 해석 불가($acct) — fail-closed" >&2; exit 5; }
    [ -n "$base" ] || { echo "[cys-dept] allocate: 기본계정 base 빈값($acct) — fail-closed" >&2; exit 5; }
    acctdir="${base%/}-$name"; mkdir -p "$acctdir"
    [ -d "$acctdir" ] || { echo "[cys-dept] allocate: account fork dir 생성 실패: $acctdir — fail-closed" >&2; exit 5; }
    mkdir -p "$(dept_logdir "$name")" "$pack/directives"
    seed_acl "$pack"
    if ready "$sock"; then echo "[cys-dept] $name 이미 가동 중 — 재사용" >&2
    else
      # ★계정 격리: 데몬을 CYS_ACCOUNT_DIR(fork dir)와 함께 spawn (create와 동형).
      CYS_SOCKET="$sock" CYS_PACK_DIR="$pack" CYS_ACCOUNT_DIR="$acctdir" nohup "$CYSD" >"$(dept_logdir "$name")/cysd.log" 2>&1 &
      disown
      ready "$sock" || { reg_remove "$name"; echo "[cys-dept] ERROR: $name 데몬 기동 실패" >&2; exit 1; }
    fi
    # ★데몬 up 확정 후 실패 trap을 풀teardown(kill+소켓+reg)으로 업그레이드 — 이후 단계 set -e 종료 시 orphan 0.
    trap '"$0" down "$name" >/dev/null 2>&1 || true' EXIT
    seed_schedule "$pack"
    ceo_promote 1>&2   # ceo_promote의 승격 메시지를 stderr로 — allocate stdout은 name만(파서 오염 차단)
    # ★Fix1' 계정격리: agents.json CLAUDE_CONFIG_DIR 을 fork dir로 치환(F1). 실패=비격리 → fail-closed teardown.
    if ! seed_agents_account "$pack" "$acctdir"; then
      echo "[cys-dept] ERROR: $name agents.json 계정시드 실패 — fail-closed: 부트 중단·teardown" >&2
      "$0" down "$name" >/dev/null 2>&1 || true; trap - EXIT; exit 6
    fi
    trap - EXIT   # 격리 확정 — 회수 취소
    # ★오너 지시(2026-06-29): 부서 생성 시 claude 자동연결 폐지 → role=master '빈 셸'만 띄운다.
    #   사용자가 그 터미널에서 직접 claude 를 실행해 부서장으로 연결한다(Decision A '부서장 자동각성'을
    #   allocate 경로에서 폐지). UI 자동입양은 role 있는 surface 만 받으므로(main.ts:1268 !s.role 가드)
    #   --role master 필수·--cmd 생략=기본 로그인 셸. CYS_DEPT_NO_MASTER=1=셸도 생략(빈 데몬). 이미 master면 멱등.
    if [ "${CYS_DEPT_NO_MASTER:-0}" = 1 ]; then
      echo "[cys-dept] $name CYS_DEPT_NO_MASTER=1 — 셸 미생성(빈 데몬)" >&2
    elif dept_has_master "$sock"; then
      echo "[cys-dept] $name 이미 master surface 존재 — 셸 생성 생략(멱등)" >&2
    elif CYS_SOCKET="$sock" "$CYS" new-surface --socket "$sock" --role master --cwd "${CYS_DEPT_CWD:-$HOME}" >/dev/null 2>&1; then
      echo "[cys-dept] $name role=master 빈 셸 생성 완료 — 사용자가 직접 claude 연결 (cwd=${CYS_DEPT_CWD:-$HOME})" >&2
    else
      echo "[cys-dept] WARN: $name 셸 생성 실패 — read-screen 점검(데몬·격리는 정상)" >&2
    fi
    echo "[cys-dept] $name allocate 완료 (sock=$sock acct=$acctdir)" >&2
    echo "$name"   # ★stdout 마지막 줄 = 확정 name (Tauri 파싱). 진단은 전부 >&2
    ;;
  create)
    # ＋부서 자동화: 카탈로그 기반 완전 자동 부서 생성(부서명·계정·미션·각성). 레거시 allocate 무변경.
    key="${2:?usage: cys-dept create <catalog-key>}"
    CAT="${CYS_DEPT_CATALOG:-$HOME/.cys/dept-catalog.json}"
    MISS="${CYS_DEPT_MISSIONS:-$HOME/.cys/dept-missions}"
    [ -f "$CAT" ] || { echo "[cys-dept] 카탈로그 부재: $CAT (GUI=레거시 allocate fallback)" >&2; exit 3; }  # fail-closed
    # 카탈로그 조회 + account dir 해석($HOME 전개). 파싱실패/키부재=fail-closed.
    IFS=$'\t' read -r disp acctkey acctdir mkey cwd < <(python3 - "$CAT" "$key" <<'PY'
import json,sys,os
cat,key=sys.argv[1:3]
d=json.load(open(cat))                                   # 파싱실패=예외=비0=fail-closed
dep=d['departments'].get(key)
if not dep: sys.exit(4)
acct=dep['account']; acctdir=os.path.expandvars(d['accounts'][acct])
# 탭 구분(codex 비차단 하드닝): display/cwd 에 공백 있어도 필드 안 깨짐(공백필드 취약성 제거)
print('\t'.join([dep['display'], acct, acctdir, dep['mission_key'], os.path.expandvars(dep['cwd'])]))
PY
) || { echo "[cys-dept] 카탈로그 키 미정의/손상: $key" >&2; exit 4; }
    # 부서별 config dir 분리(오너 결정): primary(공유) 계정→부서별 dir(~/.cys/claude-<key>)로 config state 경합 완화.
    # primary 계정 키는 env CYS_PRIMARY_ACCOUNT로 외부화(기본 'owner')·오너는 자기 primary 핸들 값으로 설정하면 동일 동작 유지.
    # Max 계정 토큰은 macOS Keychain(계정단위)으로 공유 유지·dir만 분리. 단독 계정(부서 1개)은 이미 단독이라 불변.
    if [ "$acctkey" = "${CYS_PRIMARY_ACCOUNT:-owner}" ]; then acctdir="${acctdir%/}-$key"; mkdir -p "$acctdir"; fi
    [ -d "$acctdir" ] || { echo "[cys-dept] account dir 미존재(계정누수 차단): $acctdir" >&2; exit 5; }  # fail-closed
    # F3(codex): 멱등검사+예약을 단일 flock 원자. ★같은 mission_key 엔트리=청구됨 → REUSE(데몬 생사 무관·
    #   호출부가 ensure-ready). 신규는 lowest-unused 예약 + ★엔트리에 mission_key 기록(동시/부팅중 다른
    #   create가 즉시 발견 — codex: NEW 엔트리에 mission_key 누락 TOCTOU 해소).
    res=$(reg_init; CYS_GRACE="${CYS_DEPT_RESERVE_GRACE:-25}" python3 - "$REG" "$mkey" "$cwd" "$acctdir" <<'PY'
import json,sys,os,re,time,socket as S
try:
    import fcntl
    def _lk(f): fcntl.flock(f, fcntl.LOCK_EX)
    def _ulk(f): fcntl.flock(f, fcntl.LOCK_UN)
except ImportError:  # RC-6 Windows: fcntl 부재 → msvcrt 바이트락(파일 닫힘 시 해제·_ulk no-op 안전)
    import msvcrt
    def _lk(f):
        try: msvcrt.locking(f.fileno(), msvcrt.LK_LOCK, 1)
        except OSError: pass
    def _ulk(f): pass
p,mkey,cwd,acctdir=sys.argv[1:5]
home=os.path.expanduser('~'); GRACE=float(os.environ.get("CYS_GRACE","25"))
import subprocess
def _sk_named(nm):  # RC-6: OS별 부서 소켓(bash dept_sock 규약 미러) — Windows named pipe·unix .sock
    return (r"\\.\pipe\cys-dept-%s"%nm) if os.name=="nt" else f"{home}/.local/state/cys-dept-{nm}/cys.sock"
def alive_sock(sk):  # RC-6: AF_UNIX→cys ping(named pipe 대응·os.path.exists는 pipe에 False라 제거)
    if not sk: return False
    try: return subprocess.run([os.environ.get("CYS_BIN","cys"),"ping"], env={**os.environ,"CYS_SOCKET":sk},
                               capture_output=True, timeout=3).returncode==0
    except Exception: return False
lf=open(p+'.lock','w'); _lk(lf)
try:
    try: d=json.load(open(p))
    except Exception: d={'depts':{}}
    depts=d.setdefault('depts',{}); now=time.time()
    # 멱등(원자): 같은 mission_key 엔트리=청구됨 → REUSE. 死活+reserved_at grace로 3분기(CSO 봉인):
    #   UP=서빙중 즉시반환 / BOOTING=생성자 부팅중(grace내)→신뢰·반환(boot tail 안 함=더블각성·더블미션 봉인)
    #   DEAD=grace 경과·미생존→호출부 ensure-up revive. (grace 없으면 부팅중을 死로 오판→ensure-up 더블부트)
    for n,e in depts.items():
        if e.get('mission_key')!=mkey: continue
        if alive_sock(e.get('socket','')): print("REUSE_UP "+n); sys.exit(0)
        if now-float(e.get('reserved_at',0))<GRACE: print("REUSE_BOOTING "+n); sys.exit(0)
        # ★R3.1(CSO·codex R3-REUSE-DEAD-CONCURRENT-REVIVE+META-STALE): 반환 전 같은 flock에서
        #   reserved_at=now 재청구 + cwd/account_dir 최신 catalog로 갱신 → 동시 follower=REUSE_BOOTING(더블부트 봉인)·메타 최신.
        e['reserved_at']=now; e['cwd']=cwd; e['account_dir']=acctdir
        tmp=p+'.tmp.%d'%os.getpid()
        with open(tmp,'w') as f: json.dump(d,f,ensure_ascii=False,indent=2); f.flush(); os.fsync(f.fileno())
        os.replace(tmp,p)
        print("REUSE_DEAD "+n); sys.exit(0)
    # ★[2] hard cap(NEW 분기만·reserve flock 안 — 동시성·원자성 유지): REUSE는 면제, 죽은(미reap) 등록은
    #   빼고 ★살아있는 데몬만 카운트(상단 alive_sock 재사용) — 신규 예약 전 live 수 ≥ cap 거부(exit 8).
    CAP=int(os.environ.get("CYS_DEPT_CAP","8"))
    live=sum(1 for e in depts.values() if alive_sock(e.get('socket','')))
    if live>=CAP:
        sys.stderr.write("[cys-dept] create NEW 거부: live 부서 수 %d ≥ CYS_DEPT_CAP=%d (hard cap·죽은등록 제외)\n"%(live,CAP)); sys.exit(8)
    # 신규 예약(lowest-unused·소켓 점유 번호 skip) — mission_key+reserved_at+메타 즉시 원자기록
    used={int(m.group(1)) for k in depts if (m:=re.match(r'^dept-(\d+)$',k))}
    N=1
    while N in used or alive_sock(_sk_named("dept-%d"%N)): N+=1
    name=f"dept-{N}"
    depts[name]={'socket':_sk_named(name),
                 'pack_dir':f"{home}/.cys/pack-dept-{name}",'role':'dept-master',
                 'mission_key':mkey,'cwd':cwd,'account_dir':acctdir,'reserved_at':now}
    tmp=p+'.tmp.%d'%os.getpid()
    with open(tmp,'w') as f: json.dump(d,f,ensure_ascii=False,indent=2); f.flush(); os.fsync(f.fileno())
    os.replace(tmp,p)
    print("NEW "+name)
finally: _ulk(lf)
PY
) || exit $?   # ★cap 거부(exit 8) 등 예약 실패 코드 그대로 전파
    verb="${res%% *}"; name="${res#* }"
    [ -n "$name" ] || { echo "[cys-dept] create: 예약 실패" >&2; exit 1; }
    sock="$(dept_sock "$name")"; pack="$(dept_pack "$name")"
    # 멱등 3분기 봉인(CSO): UP/BOOTING=즉시반환(boot tail 안 함=더블각성·더블미션 봉인)·DEAD=ensure-up revive·NEW=신규.
    case "$verb" in
      REUSE_UP)      echo "[cys-dept] $key 이미 생존($name) — 재사용" >&2; echo "$name"; exit 0 ;;
      REUSE_BOOTING) echo "[cys-dept] $key 생성자 부팅중($name) — 신뢰·재사용(중복부트 차단)" >&2; echo "$name"; exit 0 ;;
      REUSE_DEAD)    echo "[cys-dept] $key 등록부 잔존($name)·데몬 사망(grace 경과) → ensure-up 재기동" >&2 ;;
      NEW)           : ;;
      *)             echo "[cys-dept] create: 미지 verb '$verb'" >&2; exit 1 ;;
    esac
    # ── ensure-up: 데몬 기동 + 시드 + 격리 + 부서장 (NEW · REUSE-사망 공통) ──
    if [ "$verb" = "NEW" ]; then trap 'reg_remove "$name" 2>/dev/null || true' EXIT; fi  # NEW만 실패 시 예약회수(REUSE는 기존 보존)
    mkdir -p "$(dept_logdir "$name")" "$pack/directives"
    seed_acl "$pack"
    if ready "$sock"; then echo "[cys-dept] $name 이미 가동 — 재사용" >&2
    else
      # ★계정 격리: 데몬을 CYS_ACCOUNT_DIR 와 함께 spawn(patch2 있으면 자식 전파·없으면 F1 시드가 보장)
      CYS_SOCKET="$sock" CYS_PACK_DIR="$pack" CYS_ACCOUNT_DIR="$acctdir" nohup "$CYSD" >"$(dept_logdir "$name")/cysd.log" 2>&1 &
      disown
      ready "$sock" || { if [ "$verb" = "NEW" ]; then reg_remove "$name"; fi; echo "[cys-dept] ERROR: $name 데몬 기동 실패" >&2; exit 1; }
    fi
    # ★R3.1(CSO·codex R3-REG-SET-META-ORPHAN): 데몬 up 확정 후 실패 trap을 풀teardown(down=kill+소켓+reg)으로 업그레이드.
    #   이후 reg_set_meta fail-closed/시드/각성에서 set -e 종료해도 이미 뜬 데몬 orphan 0. NEW·REUSE_DEAD 공통.
    trap '"$0" down "$name" >/dev/null 2>&1 || true' EXIT
    seed_schedule "$pack"
    ceo_promote 1>&2
    reg_set_meta "$name" "$disp" "$acctkey"   # display_name/account merge(mission_key는 예약시 원자기록·socket/role 보존)
    # F1(codex#1) ★fail-closed: agents.json 계정시드 실패 시 부트 안 함·teardown(비격리 부서장 금지·fail-open 차단).
    if ! seed_agents_account "$pack" "$acctdir"; then
      echo "[cys-dept] ERROR: $name agents.json 계정시드 실패 — fail-closed: 부트 중단·teardown" >&2
      "$0" down "$name" >/dev/null 2>&1 || true
      exit 6
    fi
    trap - EXIT   # 격리 확정 — 이후 빈 셸 생성
    # ★WP-11(오너 2026-06-29 결정 일원화): create도 allocate와 동일하게 role=master '빈 셸'만 띄운다.
    #   자동 각성(부트 노드)+미션 자동주입(send --to master)을 폐지 — 사용자가 그 셸에서 직접 claude 를
    #   실행해 부서장으로 연결하고, 부서장이 미션 파일($MISS/$key.md)을 스스로 읽는다. 빈 셸(agent=None)엔
    #   phoenix 각성핑도 미발사(stage_reinject agent-gate) → 빈 zsh 오해석 에러 0. 계정격리·미션파일은 보존.
    # ★더블master guard(부트↔수동선언 경합 좀비 방지): 이미 live master surface가 있으면 셸 생성 생략(멱등).
    if dept_has_master "$sock"; then
      echo "[cys-dept] $name 이미 live master surface 존재 — 셸 생성 생략(멱등 더블master 방지)" >&2
    elif CYS_SOCKET="$sock" "$CYS" new-surface --socket "$sock" --role master --cwd "$cwd" >/dev/null 2>&1; then
      echo "[cys-dept] $name role=master 빈 셸 생성 완료 — 사용자가 직접 claude 연결 (미션 파일: $MISS/$key.md)" >&2
    else
      echo "[cys-dept] WARN: $name 셸 생성 실패 — read-screen 점검(데몬·격리는 정상)" >&2
    fi
    echo "[cys-dept] create '$disp'($name) 완료 (account=$acctkey sock=$sock)" >&2
    echo "$name"   # stdout 마지막 = 확정 name(Tauri 파싱)
    ;;
  down)
    name="${2:?usage: cys-dept down <name>}"
    sock="$(dept_sock "$name")"
    # ★NO_AUTOSTART(감사 2026-07-10): 죽은 부서 down 시 identify가 cysd를 되살려 그걸 kill하던 낭비 spawn 제거
    # — 실패 시 pid 빈값이면 아래가 kill을 건너뛰고 rm+reg_remove로 진행(종국 상태 동일).
    pid=$(CYS_NO_AUTOSTART=1 CYS_SOCKET="$sock" "$CYS" identify 2>/dev/null | python3 -c "import json,sys;print(json.load(sys.stdin).get('daemon_pid',''))" 2>/dev/null || true)
    # orphan 방지(오너 ③): kill 후 데몬 사망 확인·잔존 시 SIGKILL(down이 데몬 살린 채 reg_remove→orphan 재발 차단).
    if [ -n "${pid:-}" ]; then
      graceful_kill "$pid"
    fi
    rm -f "$sock" "$sock.lock" 2>/dev/null || true
    reg_remove "$name"
    dept_tombstone "$name"
    [ "$(reg_count)" = "0" ] && ceo_demote || true
    echo "[cys-dept] $name 종료·정리 완료. 부서 수=$(reg_count)"
    ;;
  down-sock)
    # socket 기준 teardown — ws rename으로 name↔socket이 끊겨도 정확히 종료(레지스트리 역인덱스).
    sock="${2:?usage: cys-dept down-sock <socket>}"
    name=$(reg_init; python3 - "$REG" "$sock" <<'PY'
import json,sys
p,s=sys.argv[1:3]
d=json.load(open(p)).get('depts',{})
for n,e in d.items():
    if e.get('socket')==s: print(n); break
PY
)
    pid=$(CYS_NO_AUTOSTART=1 CYS_SOCKET="$sock" "$CYS" identify 2>/dev/null | python3 -c "import json,sys;print(json.load(sys.stdin).get('daemon_pid',''))" 2>/dev/null || true)
    if [ -n "${pid:-}" ]; then
      graceful_kill "$pid"
    fi
    rm -f "$sock" "$sock.lock" 2>/dev/null || true
    [ -n "$name" ] && reg_remove "$name" || true
    [ -n "$name" ] && dept_tombstone "$name" || true
    [ "$(reg_count)" = "0" ] && ceo_demote || true
    echo "[cys-dept] socket teardown 완료(name=${name:-미등록}). 부서 수=$(reg_count)"
    ;;
  rotate)
    # ★버전 스큐 세대교체(재기동, ★폐기 아님): 데몬 프로세스만 정지→새 on-disk cysd로 재기동한다.
    # down(reg_remove+dept_tombstone+ceo_demote=의도적 폐기)과 달리 레지스트리·묘비·CEO를 절대 건드리지
    # 않는다 — CSO 단일소유 부서 생성/폐기 권한 불침범(rotate=순수 재기동). launch 로직을 재귀 재사용해
    # reg_upsert(merge·메타보존)+새 바이너리 spawn+seed+ceo_promote를 재확립한다.
    name="${2:?usage: cys-dept rotate <name>}"
    sock="$(dept_sock "$name")"
    # ★필수2(A·리뷰) 사전 게이트: 미등재(down됨/없음) 부서는 즉시 중단(exit 8·부활 금지). ping/identify(autostart
    # 부작용) 이전에 레지스트리(SOT)부터 확인해 side-effect 0으로 빠르게 거부한다. reg_names(SOT) 재사용.
    if ! reg_names | grep -Fxq "$name"; then
      echo "[cys-dept] $name 미등재(down됨) — rotate 중단(부활 금지)" >&2
      exit 8
    fi
    # ★필수4(B·리뷰): rotate 대상 데몬이 실제 살아있는지 ping으로 먼저 확인(autostart 없는 연결 프로브).
    # ★함정: `cys identify`는 죽은 소켓에서 cysd를 autostart하는 부작용이 있어(스모크 실증) pid가 항상 채워져
    # "미확인" 판정을 못 한다 → ping(연결만·autostart 없음)으로 게이트한다. 미응답=소유자 사망 미확인이므로
    # 중단(exit 9): 이 상태에서 kill·rm·launch로 가면 유령 중복/오kill 위험. detectSkew가 방금 daemon_status
    # 성공한 부서만 넘기므로 이 실패는 일시적 — 다음 tick 재시도가 옳다(되살리기·중복 금지).
    if ! CYS_SOCKET="$sock" "$CYS" ping >/dev/null 2>&1; then
      echo "[cys-dept] $name 데몬 미응답(ping 실패) — rotate 중단(소유자 사망 미확인·유령 중복 방지)" >&2
      exit 9
    fi
    # 살아있음이 확인됐으니 identify는 실 데몬에 연결(autostart 없음). 구 버전(검증 게이트)·pid(kill 대상) 취득.
    oldver="$(CYS_NO_AUTOSTART=1 CYS_SOCKET="$sock" "$CYS" identify 2>/dev/null | python3 -c "import json,sys;print(json.load(sys.stdin).get('version',''))" 2>/dev/null || true)"
    pid=$(CYS_NO_AUTOSTART=1 CYS_SOCKET="$sock" "$CYS" identify 2>/dev/null | python3 -c "import json,sys;print(json.load(sys.stdin).get('daemon_pid',''))" 2>/dev/null || true)
    # 방어적 재확인(ping↔identify 사이 경합으로 pid 비면 중단 — 위와 동일 근거).
    if [ -z "${pid:-}" ]; then
      echo "[cys-dept] $name pid 미확인 — rotate 중단(소유자 사망 미확인·유령 중복 방지)" >&2
      exit 9
    fi
    # 프로세스만 종료(down의 graceful_kill 재사용 — OS중립·Windows taskkill 분기 포함, 신설 분기 없음).
    # graceful_kill이 사망을 동기 확인하므로 아래 launch의 ready 프로브가 죽은 소켓을 새것으로 오인하지 않는다.
    graceful_kill "$pid"
    rm -f "$sock" "$sock.lock" 2>/dev/null || true
    # ★필수2(A·리뷰) TOCTOU 재확인: kill·rm 도중 CSO down(reg_remove+dept_tombstone)이 레이스로 끼어들어
    # 폐기됐으면 launch(부활) 금지 — 사전 게이트 이후 창을 최소화하려 launch 직전에 한 번 더 확인(미등재→exit 8).
    if ! reg_names | grep -Fxq "$name"; then
      echo "[cys-dept] $name 미등재(down됨·rotate 중 폐기) — rotate 중단(부활 금지)" >&2
      exit 8
    fi
    # launch 재귀 호출: 소켓이 죽었으니 새 바이너리로 재spawn. CYS_ROLE 그대로 상속(게이트 통과 주체 동일).
    # launch stdout은 로그로 흘리고, 아래서 새 버전을 확정 출력한다.
    bash "$0" launch "$name" || { echo "[cys-dept] ERROR: $name rotate 재기동 실패" >&2; exit 1; }
    newver="$(CYS_NO_AUTOSTART=1 CYS_SOCKET="$sock" "$CYS" identify 2>/dev/null | python3 -c "import json,sys;print(json.load(sys.stdin).get('version',''))" 2>/dev/null || true)"
    # ★검증 게이트(지시3): Rust/UI 성공 판정·사람 로그 확인용 — 마지막 줄에 확정 출력.
    echo "rotated $name: v${oldver:-?}→v${newver:-?}"
    ;;
  reap)
    # idle reaper: depts.json 순회 — ①소켓 死 등록 reg_remove ②유휴(live master 부재 AND agent-backed
    # 비-cso/리뷰어 live surface 부재 · grace 경과) 데몬 down-sock teardown. 판정=read-only(socket probe·
    # surface.list RPC). Phase1=flock 직렬화 레지스트리 스냅샷, Phase2=집행(flock 밖, ★kill 직전 원자 재검증).
    # --dry: 판정만(무변경). grace=CYS_DEPT_REAP_GRACE(기본 60s). 실집행: reg_remove/down-sock(각자 자체 flock).
    dry=0; [ "${2:-}" = "--dry" ] && dry=1
    reg_init
    # Phase 1 — flock 직렬화 스냅샷: 레지스트리(name·socket·reserved_at) 일관 덤프(read-only·짧은 락).
    snap=$(python3 - "$REG" <<'PY'
import json,sys
try:
    import fcntl
    def _lk(f): fcntl.flock(f, fcntl.LOCK_EX)
    def _ulk(f): fcntl.flock(f, fcntl.LOCK_UN)
except ImportError:  # RC-6 Windows: fcntl 부재 → msvcrt 바이트락(파일 닫힘 시 해제·_ulk no-op 안전)
    import msvcrt
    def _lk(f):
        try: msvcrt.locking(f.fileno(), msvcrt.LK_LOCK, 1)
        except OSError: pass
    def _ulk(f): pass
p=sys.argv[1]
lf=open(p+'.lock','w'); _lk(lf)
try:
    try: d=json.load(open(p))
    except Exception: d={'depts':{}}
    for n,e in d.get('depts',{}).items():
        print("%s\t%s\t%s"%(n, e.get('socket',''), e.get('reserved_at',0) or 0))
finally: _ulk(lf)
PY
) || { echo "[cys-dept] reap: 스냅샷 실패" >&2; exit 1; }
    # 분류+집행(flock 밖·probe). reg_remove/down-sock는 각자 자체 flock·원자. 현재 셸 루프(카운터 보존).
    nd=0; ni=0; ns=0
    while IFS=$'\t' read -r nm sk rat; do
      [ -n "$nm" ] || continue
      if ! sock_alive "$sk"; then
        nd=$((nd+1))
        if [ "$dry" = 1 ]; then echo "[cys-dept] reap(dry): DEAD $nm (sock 死) → reg_remove"
        else echo "[cys-dept] reap: DEAD $nm → reg_remove"; reg_remove "$nm"; fi
        continue
      fi
      cls="$(dept_classify_idle "$sk" "$rat")"
      if [ "$cls" != "IDLE" ]; then ns=$((ns+1)); echo "[cys-dept] reap: SKIP $nm (활동: $cls)" >&2; continue; fi
      if [ "$dry" = 1 ]; then ni=$((ni+1)); echo "[cys-dept] reap(dry): IDLE $nm → down-sock teardown"; continue; fi
      # ★[5] TOCTOU 차단: kill(down-sock) 직전 원자 재검증 — 스냅샷 이후 master/agent가 붙었으면 회수 취소.
      recls="ACTIVE:gone"; sock_alive "$sk" && recls="$(dept_classify_idle "$sk" "$rat")"
      if [ "$recls" = "IDLE" ]; then
        ni=$((ni+1)); echo "[cys-dept] reap: IDLE $nm → down-sock teardown"; "$0" down-sock "$sk" >/dev/null 2>&1 || true
      else
        ns=$((ns+1)); echo "[cys-dept] reap: SKIP $nm — 집행직전 재검증서 활동전환($recls), teardown 취소(TOCTOU 보호)" >&2
      fi
    done <<EOF
$snap
EOF
    echo "[cys-dept] reap 완료(dry=$dry): DEAD=$nd IDLE=$ni SKIP=$ns. 부서 수=$(reg_count)"
    ;;
  list) reg_names ;;
  sock) dept_sock "${2:?usage: cys-dept sock <name>}" ;;
  *)
    name="$cmd"; shift; [ "${1:-}" = "--" ] && shift
    [ "$#" -ge 1 ] || { echo "usage: cys-dept <name> -- <cmd>" >&2; exit 2; }
    export CYS_SOCKET="$(dept_sock "$name")" CYS_PACK_DIR="$(dept_pack "$name")"
    exec "$@"
    ;;
esac
